{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "NextJs",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "console": "internalConsole",
            "serverReadyAction": {
                "action": "debugWithChrome",
                "pattern": "http://localhost:(\\d+)",
                "uriFormat": "http://localhost:%s"
            }
        },
    ],
}